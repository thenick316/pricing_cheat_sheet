<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Roofline Permanent Lighting — Pricing Cheat Sheet</title>
  <style>
    :root {
      --bg:#0f172a;
      --panel:#111827;
      --accent:#22c55e;
      --accent-2:#38bdf8;
      --text:#e5e7eb;
      --sub:#9ca3af;
    }
    body {background:var(--bg);color:var(--text);font-family:Inter,sans-serif;margin:0;padding:24px}
    h1 {font-size:24px;margin:0 0 8px}
    h2 {font-size:18px;margin:16px 0 8px;color:var(--accent-2);cursor:pointer}
    p {color:var(--sub);margin:0 0 12px}

    .panel {background:linear-gradient(180deg, var(--panel), #0b1220);border:1px solid #1f2937;border-radius:12px;padding:16px;margin-bottom:16px}
    .row {display:flex;gap:12px;align-items:center;margin:8px 0}
    label {font-size:13px;color:var(--sub);min-width:160px}
    input[type="number"], select {
      width:100%;background:#1a2332;color:var(--text);
      border:2px solid #475569;border-radius:8px;padding:10px;font-weight:500;
    }
    input[type="checkbox"]{transform:scale(1.2)}
    .btn {background:var(--accent);color:#052e16;border:none;padding:10px 14px;border-radius:10px;font-weight:700;cursor:pointer}
    .btn.secondary{background:#1f2937;color:#e5e7eb;border:1px solid #334155}

    .hidden {display:none}
    .toggle-sub {font-size:12px;color:var(--sub);margin-left:8px}
    .run-row {display:flex;gap:12px;align-items:center;margin:6px 0}
    .run-label {font-size:13px;color:var(--sub);min-width:160px}
    .total-ft {font-size:14px;font-weight:700;color:var(--accent);margin-top:8px;padding:8px 0;border-top:1px dashed #334155}
    table{width:100%;margin-top:10px;border-collapse:separate;border-spacing:0 8px}
    th,td{text-align:right;padding:8px}
    th{color:#cbd5e1;font-weight:600;border-bottom:1px dashed #334155}
    td:first-child,th:first-child{text-align:left}
    .summary{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-top:12px}
    .card{background:#0b1324;border:1px solid #1f2937;border-radius:12px;padding:16px}
    .kpi{font-size:20px;font-weight:700}
  </style>
</head>
<body>
  <h1>Roofline Permanent Lighting — Pricing Cheat Sheet</h1>
  <p>Interactive estimator with live cost breakdown and per‑foot pricing</p>

  <!-- PROJECT DETAILS -->
  <div class="panel">
    <h2>Project Details</h2>
    <div class="row">
      <label>Number of Runs</label>
      <select id="numRuns" onchange="updateRunInputs()">
        <option value="1">1</option>
        <option value="2">2</option>
        <option value="3">3</option>
        <option value="4">4</option>
        <option value="5">5</option>
      </select>
    </div>
    <div id="runsContainer"></div>
    <div class="total-ft" id="totalFtDisplay">Total Linear Footage: 0 ft</div>
    <div class="row"><label>Apply material waste (%)</label><input id="wastePct" type="number" step="0.1" min="0" value="0"/></div>
    <div class="row"><label>Control system</label>
      <select id="controlOption">
        <option value="500">Proprietary — $500</option>
        <option value="1000">DMX — $1,000</option>
      </select>
    </div>
    <div class="row"><label>Installation method</label>
      <select id="installMethod">
        <option value="backer">Backer Channel</option>
        <option value="clip">Clip</option>
      </select>
    </div>
  </div>

  <!-- LABOR INPUTS (expandable) -->
  <div class="panel">
    <h2 onclick="toggleSection('labor-section')">Labor Inputs <span class="toggle-sub">(expand to enter labor details)</span></h2>
    <div id="labor-section" class="hidden">
      <div class="row"><label>Install hours (est.)</label><input id="laborHours" type="number" step="0.1" min="0" value="0"/></div>
      <div class="row"><label>Labor rate ($/hr)</label><input id="laborRate" type="number" step="1" min="0" value="0"/></div>
      <div class="row"><label>Sales markup on cost (%)</label><input id="markupPct" type="number" step="0.5" min="0" value="0"/></div>
      <div class="row"><label>Travel/Misc (fixed $)</label><input id="miscFixed" type="number" step="1" min="0" value="0"/></div>
    </div>
  </div>

  <!-- PROJECT ASSUMPTIONS (was BOM) -->
  <div class="panel">
    <h2 onclick="toggleSection('bom-section')">Project Assumptions <span class="toggle-sub">(expand to view material inputs)</span></h2>
    <div id="bom-section" class="hidden">
      <div class="row"><label>Backer $/ft</label><input id="priceBacker" type="number" step="0.01" min="0" value="2.37"/></div>
      <div class="row"><label>Face $/ft</label><input id="priceFace" type="number" step="0.01" min="0" value="2.88"/></div>
      <div class="row"><label>Chaser $/ft</label><input id="priceChaser" type="number" step="0.01" min="0" value="3.11"/></div>
      <div class="row"><label>45° $/ft</label><input id="priceAngle" type="number" step="0.01" min="0" value="4.13"/></div>
      <div class="row"><label>Clip price (ea)</label><input id="priceClip" type="number" step="0.01" min="0" value="0.50"/></div>

      <div class="row"><label>Dot unit price ($)</label><input id="priceDot" type="number" step="0.01" min="0" value="6.03"/></div>
      <div class="row"><label>Power inject $</label><input id="priceInject" type="number" step="0.01" min="0" value="40"/></div>
      <div class="row"><label>Jumpers qty</label><input id="qtyJumper" type="number" step="1" min="0" value="10"/></div>
      <div class="row"><label>Jumper $</label><input id="priceJumper" type="number" step="0.01" min="0" value="4.79"/></div>
      <div class="row"><label>T‑connectors qty</label><input id="qtyT" type="number" step="1" min="0" value="4"/></div>
      <div class="row"><label>T‑connector $</label><input id="priceT" type="number" step="0.01" min="0" value="11.80"/></div>
    </div>
  </div>

  <!-- COST BREAKDOWN -->
  <div class="panel">
    <h2>Detailed Cost Breakdown</h2>
    <table>
      <thead><tr><th>Component</th><th>Units</th><th>Qty</th><th>Unit $</th><th>Ext. $</th></tr></thead>
      <tbody id="breakdownBody"></tbody>
    </table>

    <div class="summary">
      <div class="card"><div class="muted">Materials subtotal</div><div id="materialsSubtotal" class="kpi">$0.00</div></div>
      <div class="card"><div class="muted">Waste add‑on</div><div id="wasteAdd" class="kpi">$0.00</div></div>
      <div class="card"><div class="muted">Labor + Misc</div><div id="laborMisc" class="kpi">$0.00</div></div>
      <div class="card"><div class="muted">Control system</div><div id="controlCost" class="kpi">$0.00</div></div>
    </div>

    <div class="summary">
      <div class="card"><div class="muted">Cost (pre‑markup)</div><div id="preMarkup" class="kpi">$0.00</div></div>
      <div class="card"><div class="muted">Markup $</div><div id="markupValue" class="kpi">$0.00</div></div>
      <div class="card"><div class="muted">Selling price</div><div id="sellPrice" class="kpi">$0.00</div></div>
      <div class="card"><div class="muted">$/ft (sell)</div><div id="perFtSell" class="kpi">$0.00</div></div>
    </div>
  </div>

  <script>
    const $ = id => document.getElementById(id);

    function toggleSection(id){
      $(id).classList.toggle('hidden');
    }

    function money(n){
      return n.toLocaleString(undefined,{style:'currency',currency:'USD',maximumFractionDigits:2});
    }
    function num(id){const v=parseFloat($(id).value);return isNaN(v)?0:v;}
    function numEl(el){const v=parseFloat(el.value);return isNaN(v)?0:v;}

    function updateRunInputs(){
      const n = parseInt($('numRuns').value);
      const container = $('runsContainer');
      // Preserve existing values
      const existing = [];
      container.querySelectorAll('input').forEach(inp => existing.push(inp.value));
      container.innerHTML = '';
      for(let i=1;i<=n;i++){
        const row = document.createElement('div');
        row.className = 'run-row';
        row.innerHTML = `<label class="run-label">Run ${i} — Linear ft</label><input type="number" step="1" min="0" value="${existing[i-1]||0}" class="run-input" oninput="updateTotal()" onchange="updateTotal()"/>`;
        container.appendChild(row);
      }
      updateTotal();
    }

    function updateTotal(){
      const inputs = document.querySelectorAll('.run-input');
      let total = 0;
      inputs.forEach(inp => total += numEl(inp));
      $('totalFtDisplay').textContent = `Total Linear Footage: ${total} ft`;
      compute();
    }

    function getTotalFt(){
      let total = 0;
      document.querySelectorAll('.run-input').forEach(inp => total += numEl(inp));
      return total;
    }

    function compute(){
      const ft = getTotalFt();
      const numRuns = parseInt($('numRuns').value);
      const dotSpacing = 9; // fixed (inches)
      const dots = Math.ceil((ft*12)/dotSpacing);

      // Assumptions & unit prices
      const priceBacker=num('priceBacker'), priceFace=num('priceFace'), priceChaser=num('priceChaser'), priceAngle=num('priceAngle');
      const priceDot=num('priceDot'), priceInject=num('priceInject');
      const priceJumper=num('priceJumper'), qtyJumper=num('qtyJumper');
      const priceT=num('priceT'), qtyT=num('qtyT');
      const priceClip=num('priceClip');
      const installMethod=$('installMethod').value;

      // Power injection qty = number of runs (1:1)
      const qtyInject = numRuns;

      // Compute quantities using updated formulas
      const lenBacker = ft;
      const lenFace   = ft * 0.80;
      const lenChaser = ft * 0.10;
      const lenAngle  = ft * 0.10;

      // Extended costs
      let extBacker=0, extClips=0;
      if(installMethod==="backer"){
        extBacker = lenBacker * priceBacker;
      } else {
        const clipQty = Math.ceil(ft * 0.61);
        extClips = clipQty * priceClip;
      }
      const extFace    = lenFace    * priceFace;
      const extChaser  = lenChaser  * priceChaser;
      const extAngle   = lenAngle   * priceAngle;
      const extDots    = dots       * priceDot;
      const extInject  = qtyInject  * priceInject;
      const extJumper  = qtyJumper  * priceJumper;
      const extT       = qtyT       * priceT;

      const materials = extBacker+extFace+extChaser+extAngle+extDots+extInject+extJumper+extT+extClips;
      const wasteAdd  = materials * (num('wastePct')/100);

      const laborMisc = (num('laborRate') * num('laborHours')) + num('miscFixed');
      const control   = parseFloat($('controlOption').value);
      const preMarkup = materials + wasteAdd + laborMisc + control;
      const markupVal = preMarkup * (num('markupPct')/100);
      const sell      = preMarkup + markupVal;
      const perFtSell = ft > 0 ? sell / ft : 0;

      // Breakdown table
      const rows = [];
      if(installMethod==="backer") rows.push(['Backer channel','ft',lenBacker.toFixed(1),priceBacker,extBacker]);
      else rows.push(['Clips','ea',Math.ceil(ft*0.61),priceClip,extClips]);
      rows.push(['Channel face','ft',lenFace.toFixed(1),priceFace,extFace]);
      rows.push(['Chaser channel','ft',lenChaser.toFixed(1),priceChaser,extChaser]);
      rows.push(['45° angle parts','ft',lenAngle.toFixed(1),priceAngle,extAngle]);
      rows.push(['Pixel dots','ea',dots,priceDot,extDots]);
      rows.push(['Power injection','ea',qtyInject,priceInject,extInject]);
      rows.push(['Jumpers','ea',qtyJumper,priceJumper,extJumper]);
      rows.push(['T‑connectors','ea',qtyT,priceT,extT]);
      rows.push(['Control system','ea',1,control,control]);

      $('breakdownBody').innerHTML = rows.map(r=>`<tr><td>${r[0]}</td><td>${r[1]}</td><td>${r[2]}</td><td>${money(r[3])}</td><td>${money(r[4])}</td></tr>`).join('');

      // KPIs
      $('materialsSubtotal').textContent = money(materials);
      $('wasteAdd').textContent          = money(wasteAdd);
      $('laborMisc').textContent         = money(laborMisc);
      $('controlCost').textContent       = money(control);
      $('preMarkup').textContent         = money(preMarkup);
      $('markupValue').textContent       = money(markupVal);
      $('sellPrice').textContent         = money(sell);
      $('perFtSell').textContent         = money(perFtSell);
    }

    document.querySelectorAll('input,select').forEach(el=>{
      el.addEventListener('input', compute);
      el.addEventListener('change', compute);
    });

    // Initialize run inputs on load
    updateRunInputs();
  </script>
</body>
</html>
